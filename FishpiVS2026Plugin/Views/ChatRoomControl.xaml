<UserControl
    x:Class="FishpiVS2026Plugin.Views.ChatRoomControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cvt="clr-namespace:FishpiVS2026Plugin.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:FishpiVS2026Plugin"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:FishpiVS2026Plugin.Models"
    xmlns:vsshell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
    Name="MyToolWindow"
    d:DesignHeight="300"
    d:DesignWidth="300"
    local:LoadedCommandBehavior.LoadedCommand="{Binding OnLoadedCommand}"
    Background="{DynamicResource {x:Static vsshell:VsBrushes.WindowKey}}"
    Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
    mc:Ignorable="d">
    <!--<i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding OnLoadedCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>-->
    <UserControl.Resources>
        <cvt:BoolToHorizontalAlignmentConverter x:Key="BoolToHorizontalAlignmentConverter" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <!--  聊天消息列表  -->
        <ListView
            x:Name="ChatListView"
            Background="Transparent"
            BorderThickness="0"
            Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
            ItemsSource="{Binding Messages}"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
            ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <!--  虚拟化面板  -->
                    <VirtualizingStackPanel Orientation="Vertical" />
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>

            <!--  自定义消息项模板  -->
            <ListView.ItemTemplate>
                <DataTemplate DataType="{x:Type models:ChatRoomMessage}">
                    <Grid Margin="5" HorizontalAlignment="{Binding IsSelf, Converter={StaticResource BoolToHorizontalAlignmentConverter}}">
                        <StackPanel Margin="5,0,0,0">
                            <!--  昵称  -->
                            <TextBlock
                                FontSize="14"
                                FontWeight="Bold"
                                Text="{Binding UserNickname}" />

                            <TextBlock
                                Margin="0,5,0,5"
                                FontSize="12"
                                Text="{Binding Md}"
                                TextWrapping="Wrap" />

                            <!--  时间  -->
                            <TextBlock FontSize="10" Text="{Binding Time}" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <TextBox
            Grid.Row="1"
            MaxHeight="100"
            Padding="5"
            Background="Transparent"
            FontSize="12"
            Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
            TextWrapping="Wrap" />
    </Grid>
</UserControl>
