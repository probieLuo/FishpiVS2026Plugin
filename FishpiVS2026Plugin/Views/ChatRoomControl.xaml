<UserControl
    x:Class="FishpiVS2026Plugin.Views.ChatRoomControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cvt="clr-namespace:FishpiVS2026Plugin.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:FishpiVS2026Plugin"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:FishpiVS2026Plugin.Models"
    xmlns:vsshell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
    Name="MyToolWindow"
    d:DesignHeight="300"
    d:DesignWidth="300"
    Background="{DynamicResource {x:Static vsshell:VsBrushes.WindowKey}}"
    Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
    mc:Ignorable="d">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding OnLoadedCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme
                    BaseTheme="Light"
                    PrimaryColor="DeepPurple"
                    SecondaryColor="Lime" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <cvt:BoolToHorizontalAlignmentConverter x:Key="BoolToHorizontalAlignmentConverter" />
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <materialDesign:Card
            Grid.Row="0"
            Background="{DynamicResource {x:Static vsshell:VsBrushes.WindowKey}}"
            Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}">
            <Menu materialDesign:MenuAssist.TopLevelMenuItemHeight="25" Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}">
                <MenuItem Command="{Binding OnSettingsCommand}" Header="set" />
            </Menu>
        </materialDesign:Card>

        <!--  聊天消息列表  -->
        <ListView
            x:Name="ChatListView"
            Grid.Row="1"
            Background="Transparent"
            BorderThickness="0"
            Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
            ItemsSource="{Binding Messages}"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
            ScrollViewer.VerticalScrollBarVisibility="Auto"
            Visibility="{Binding ChatViewVisibility}">
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <!--  虚拟化面板  -->
                    <VirtualizingStackPanel Orientation="Vertical" />
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>

            <!--  自定义消息项模板  -->
            <ListView.ItemTemplate>
                <DataTemplate DataType="{x:Type models:ChatRoomMessage}">
                    <Grid Margin="5" HorizontalAlignment="{Binding IsSelf, Converter={StaticResource BoolToHorizontalAlignmentConverter}}">
                        <StackPanel Margin="5,0,0,0">
                            <!--  昵称  -->
                            <TextBlock
                                FontSize="14"
                                FontWeight="Bold"
                                Text="{Binding UserNickname}" />

                            <TextBlock
                                Margin="0,5,0,5"
                                FontSize="12"
                                Text="{Binding Md}"
                                TextWrapping="Wrap" />

                            <!--  时间  -->
                            <TextBlock FontSize="10" Text="{Binding Time}" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBox
            Grid.Row="2"
            Height="50"
            MaxHeight="100"
            Padding="2"
            Background="Transparent"
            BorderThickness="1"
            FontSize="14"
            Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
            Text="{Binding SendContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            TextWrapping="Wrap"
            Visibility="{Binding ChatViewVisibility}">

            <i:Interaction.Triggers>
                <i:KeyTrigger Key="Return">
                    <i:InvokeCommandAction Command="{Binding OnSendCommand}" />
                </i:KeyTrigger>
            </i:Interaction.Triggers>
        </TextBox>

        <StackPanel
            Grid.Row="1"
            Grid.RowSpan="2"
            Visibility="{Binding SettingsViewVisibility}">
            <TextBox
                Margin="5"
                materialDesign:HintAssist.Hint="Domain"
                Text="{Binding Domain, Mode=TwoWay}" />
            <PasswordBox
                Margin="5"
                materialDesign:HintAssist.Hint="Apikey"
                materialDesign:PasswordBoxAssist.Password="{Binding Apikey, Mode=TwoWay}" />
            <Button
                Margin="5"
                HorizontalAlignment="Left"
                Background="{DynamicResource {x:Static vsshell:VsBrushes.WindowKey}}"
                Command="{Binding OnSaveSettingsCommand}"
                Content="保存配置"
                Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}" />
        </StackPanel>
    </Grid>
</UserControl>
