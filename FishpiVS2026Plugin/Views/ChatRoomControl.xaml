<UserControl x:Class="FishpiVS2026Plugin.Views.ChatRoomControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cvt="clr-namespace:FishpiVS2026Plugin.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helpers="clr-namespace:FishpiVS2026Plugin.Helpers"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:local="clr-namespace:FishpiVS2026Plugin"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:FishpiVS2026Plugin.Models"
             xmlns:vsshell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
             Name="MyToolWindow"
             d:DesignHeight="300"
             d:DesignWidth="300"
             Background="{DynamicResource {x:Static vsshell:VsBrushes.WindowKey}}"
             Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
             mc:Ignorable="d">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding OnLoadedCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Light"
                                             PrimaryColor="DeepPurple"
                                             SecondaryColor="Lime" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <cvt:BoolToHorizontalAlignmentConverter x:Key="BoolToHorizontalAlignmentConverter" />
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <TabControl>
            <TabItem Header="debug">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>

                    <ListView x:Name="ChatListView"
                              helpers:AutoScrollBehavior.SmartAutoScroll="True"
                              Background="Transparent"
                              BorderThickness="0"
                              Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
                              ItemsSource="{Binding Messages}"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.ContextMenu>
                            <ContextMenu Background="{DynamicResource {x:Static vsshell:VsBrushes.WindowKey}}"
                                         BorderThickness="0.5"
                                         Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
                                         Style="{StaticResource MaterialDesignMenu}">
                                <MenuItem Header="引用" />
                                <MenuItem Header="复制" />
                            </ContextMenu>
                        </ListView.ContextMenu>
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel Orientation="Vertical" />
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>

                        <ListView.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:ChatRoomMessage}">
                                <Grid Margin="0" HorizontalAlignment="{Binding IsSelf, Converter={StaticResource BoolToHorizontalAlignmentConverter}}">

                                    <StackPanel Margin="5,0,0,0">
                                        <TextBlock FontSize="12" FontWeight="Bold">
                                            <Run Text="{Binding UserNickname}" />
                                            <Run Text="(" />
                                            <Run Text="{Binding UserName}" />
                                            <Run Text=")" />
                                            <Run Text=" " />
                                            <Run FontSize="10" Text="{Binding Time}" />
                                        </TextBlock>

                                        <TextBlock FontSize="12"
                                                   Text="{Binding Md}"
                                                   TextWrapping="Wrap" />

                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <TextBox Grid.Row="1"
                             Height="50"
                             MaxHeight="100"
                             Padding="2"
                             Background="Transparent"
                             BorderThickness="1"
                             FontSize="14"
                             Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
                             Text="{Binding SendContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap">

                        <i:Interaction.Triggers>
                            <i:KeyTrigger Key="Return">
                                <i:InvokeCommandAction Command="{Binding OnSendCommand}" />
                            </i:KeyTrigger>
                        </i:Interaction.Triggers>
                    </TextBox>
                </Grid>
            </TabItem>

            <TabItem Header="release">
                <Grid>

                    <ListView x:Name="BreezemoonsListView"
                              helpers:AutoScrollBehavior.SmartAutoScroll="True"
                              Background="Transparent"
                              BorderThickness="1"
                              Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
                              ItemsSource="{Binding Breezemoons}"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="复制" />
                            </ContextMenu>
                        </ListView.ContextMenu>
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel Orientation="Vertical" />
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>

                        <ListView.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:ChatRoomMessage}">
                                <materialDesign:Card Background="Transparent">

                                    <StackPanel Margin="5,0,0,0">
                                        <TextBlock FontSize="12" FontWeight="Bold">
                                            <Run Text="{Binding UserNickname}" />
                                            <Run Text="(" />
                                            <Run Text="{Binding UserName}" />
                                            <Run Text=")" />
                                            <Run Text=" " />
                                            <Run FontSize="10" Text="{Binding Time}" />
                                        </TextBlock>

                                        <TextBlock FontSize="12"
                                                   Text="{Binding Md}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                </materialDesign:Card>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Button Margin="5"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Background="{DynamicResource {x:Static vsshell:VsBrushes.WindowKey}}"
                            Command="{Binding OnOpenEditCommand}"
                            Content="edit"
                            Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}" />

                </Grid>
            </TabItem>

            <TabItem Header="set">
                <StackPanel>
                    <TextBox Margin="5"
                             materialDesign:HintAssist.Hint="Domain"
                             Text="{Binding Domain, Mode=TwoWay}" />
                    <PasswordBox Margin="5"
                                 materialDesign:HintAssist.Hint="Apikey"
                                 materialDesign:PasswordBoxAssist.Password="{Binding Apikey, Mode=TwoWay}" />
                    <Button Margin="5"
                            HorizontalAlignment="Left"
                            Background="{DynamicResource {x:Static vsshell:VsBrushes.WindowKey}}"
                            Command="{Binding OnSaveSettingsCommand}"
                            Content="save"
                            Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}" />
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
