<UserControl
    x:Class="FishpiVS2026Plugin.Views.ChatRoomControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cvt="clr-namespace:FishpiVS2026Plugin.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:FishpiVS2026Plugin.Helpers"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:FishpiVS2026Plugin"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:FishpiVS2026Plugin.Models"
    xmlns:vsshell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
    Name="MyToolWindow"
    d:DesignHeight="300"
    d:DesignWidth="300"
    Background="{DynamicResource {x:Static vsshell:VsBrushes.WindowKey}}"
    Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
    mc:Ignorable="d">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding OnLoadedCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme
                    BaseTheme="Light"
                    PrimaryColor="DeepPurple"
                    SecondaryColor="Lime" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <cvt:BoolToHorizontalAlignmentConverter x:Key="BoolToHorizontalAlignmentConverter" />
            <cvt:BreezemoonContentConverter x:Key="BreezemoonContentConverter" />
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <TabControl>
            <TabItem Header="debug">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>

                    <ListView
                        x:Name="ChatListView"
                        helpers:AutoScrollBehavior.SmartAutoScroll="True"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
                        ItemsSource="{Binding Messages}"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        SelectedItem="{Binding SelectedMessage}">
                        <ListView.ContextMenu>
                            <ContextMenu
                                Background="{DynamicResource {x:Static vsshell:VsBrushes.WindowKey}}"
                                BorderThickness="0.5"
                                Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
                                Style="{StaticResource MaterialDesignMenu}">
                                <MenuItem Command="{Binding OnOpenRefCommand}" Header="引用" />
                                <MenuItem Command="{Binding OnCopyMsgCommand}" Header="复制" />
                            </ContextMenu>
                        </ListView.ContextMenu>
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel Orientation="Vertical" />
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>

                        <ListView.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:ChatRoomMessage}">
                                <Border
                                    Margin="0"
                                    BorderBrush="{DynamicResource {x:Static vsshell:VsBrushes.DebuggerDataTipInactiveSeparatorKey}}"
                                    BorderThickness="0,0,0,3">

                                    <StackPanel Margin="5,0,0,0">
                                        <TextBlock FontSize="12" FontWeight="Bold">
                                            <Run Text="{Binding UserNickname}" />
                                            <Run Text="(" />
                                            <Run Text="{Binding UserName}" />
                                            <Run Text=")" />
                                            <Run Text=" " />
                                            <Run FontSize="10" Text="{Binding Time}" />
                                        </TextBlock>

                                        <TextBlock
                                            FontSize="12"
                                            Text="{Binding Md}"
                                            TextWrapping="Wrap" />

                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <StackPanel
                        Margin="10"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom">

                        <Button
                            Width="24"
                            Height="24"
                            Margin="0,0,0,5"
                            Background="Transparent"
                            Command="{Binding OnGetActivityCommand}"
                            Content="{Binding Activity}"
                            FontSize="12"
                            Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
                            Style="{StaticResource MaterialDesignFloatingActionButton}"
                            ToolTip="活跃度/获取活跃度" />

                        <Button
                            Width="24"
                            Height="24"
                            Margin="0,0,0,5"
                            materialDesign:ButtonProgressAssist.IndicatorBackground="Transparent"
                            materialDesign:ButtonProgressAssist.IsIndicatorVisible="False"
                            Background="Transparent"
                            Command="{Binding OnGetActivityRewardCommand}"
                            Content="{materialDesign:PackIcon Kind=Scent,
                                                              Size=18}"
                            FontSize="8"
                            Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
                            Style="{StaticResource MaterialDesignFloatingActionButton}"
                            ToolTip="领取活跃奖励" />

                        <Button
                            x:Name="ArrowBottomButton"
                            Width="24"
                            Height="24"
                            Background="Transparent"
                            Click="ArrowBottomButton_Click"
                            Content="{materialDesign:PackIcon Kind=ArrowBottom,
                                                              Size=18}"
                            Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
                            Style="{StaticResource MaterialDesignFloatingActionMiniSecondaryButton}" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="5">
                        <Grid Margin="5" Visibility="{Binding RefViewVisibility}">
                            <TextBlock TextWrapping="Wrap">
                                <Run Text="引用 @" />
                                <Run Text="{Binding RefUserName}" />
                                <LineBreak />
                                <Run Text="{Binding RefContent}" />
                            </TextBlock>
                            <Button
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Background="Transparent"
                                Command="{Binding OnCancelRefCommand}"
                                Content="{materialDesign:PackIcon Kind=Close,
                                                                  Size=22}"
                                IsEnabled="{Binding DataContext.ControlsEnabled, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"
                                Style="{StaticResource MaterialDesignIconButton}"
                                ToolTip="MaterialDesignIconButton" />
                        </Grid>
                        <TextBox
                            MinHeight="50"
                            MaxHeight="200"
                            Padding="5"
                            materialDesign:HintAssist.Hint="Message"
                            Background="Transparent"
                            BorderThickness="1"
                            FontSize="14"
                            Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
                            Text="{Binding SendContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            TextWrapping="Wrap">

                            <i:Interaction.Triggers>
                                <i:KeyTrigger Key="Return">
                                    <i:InvokeCommandAction Command="{Binding OnSendCommand}" />
                                </i:KeyTrigger>
                            </i:Interaction.Triggers>
                        </TextBox>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="release">
                <materialDesign:DialogHost x:Name="ReleaseDialogHost">
                    <materialDesign:DialogHost.DialogContent>
                        <Border Background="{DynamicResource {x:Static vsshell:VsBrushes.WindowKey}}">
                            <StackPanel Margin="10">
                                <TextBox
                                    Width="300"
                                    Height="200"
                                    Margin="0,8,0,0"
                                    Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
                                    Text="{Binding PublishBreezemoon, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    TextWrapping="Wrap" />
                                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                    <Button
                                        Margin="0,8,8,0"
                                        Click="Button_Click"
                                        Content="发布"
                                        IsDefault="True"
                                        Style="{StaticResource MaterialDesignFlatButton}">
                                        <Button.CommandParameter>
                                            <system:Boolean xmlns:system="clr-namespace:System;assembly=mscorlib">
                                                True
                                            </system:Boolean>
                                        </Button.CommandParameter>
                                    </Button>
                                    <Button
                                        Margin="0,8,8,0"
                                        Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                                        Content="取消"
                                        IsCancel="True"
                                        Style="{StaticResource MaterialDesignFlatButton}">
                                        <Button.CommandParameter>
                                            <system:Boolean xmlns:system="clr-namespace:System;assembly=mscorlib">
                                                False
                                            </system:Boolean>
                                        </Button.CommandParameter>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </materialDesign:DialogHost.DialogContent>

                    <Border>
                        <Grid>
                            <ListView
                                x:Name="BreezemoonsListView"
                                helpers:AutoScrollBehavior.SmartAutoScroll="False"
                                Background="Transparent"
                                BorderThickness="1"
                                Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
                                ItemsSource="{Binding Breezemoons}"
                                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                ScrollViewer.VerticalScrollBarVisibility="Auto"
                                SelectedItem="{Binding SelectedBreezemoon}">
                                <ListView.ContextMenu>
                                    <ContextMenu
                                        Background="{DynamicResource {x:Static vsshell:VsBrushes.WindowKey}}"
                                        BorderThickness="0.5"
                                        Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
                                        Style="{StaticResource MaterialDesignMenu}">
                                        <MenuItem Command="{Binding OnCopyBreezemoonCommand}" Header="复制" />
                                    </ContextMenu>
                                </ListView.ContextMenu>
                                <ListView.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel Orientation="Vertical" />
                                    </ItemsPanelTemplate>
                                </ListView.ItemsPanel>

                                <ListView.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:BreezemoonItem}">
                                        <materialDesign:Card Background="Transparent">

                                            <StackPanel Margin="5,0,0,0">
                                                <TextBlock FontSize="12" FontWeight="Bold">
                                                    <Run Text="{Binding BreezemoonAuthorName}" />
                                                    <Run Text=" " />
                                                    <Run FontSize="10" Text="{Binding TimeAgo}" />
                                                    <Run Text=" " />
                                                    <Run FontSize="10" Text="{Binding BreezemoonCity}" />
                                                </TextBlock>

                                                <TextBlock
                                                    FontSize="12"
                                                    Text="{Binding BreezemoonContent, Converter={StaticResource BreezemoonContentConverter}}"
                                                    TextWrapping="Wrap" />
                                            </StackPanel>

                                        </materialDesign:Card>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <StackPanel
                                Margin="20"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Background="Transparent">
                                <Button
                                    Width="24"
                                    Height="24"
                                    Background="Transparent"
                                    Command="{x:Static materialDesign:DialogHost.OpenDialogCommand}"
                                    Content="{materialDesign:PackIcon Kind=Plus,
                                                                      Size=18}"
                                    Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
                                    Style="{StaticResource MaterialDesignFloatingActionMiniSecondaryButton}" />
                                <Button
                                    Width="24"
                                    Height="24"
                                    Margin="0,2,0,0"
                                    Background="Transparent"
                                    Command="{Binding OnRefreshBreezemoonsCommand}"
                                    Content="{materialDesign:PackIcon Kind=Refresh,
                                                                      Size=18}"
                                    Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
                                    Style="{StaticResource MaterialDesignFloatingActionMiniSecondaryButton}" />
                                <Button
                                    Width="24"
                                    Height="24"
                                    Margin="0,2,0,0"
                                    Background="Transparent"
                                    Command="{Binding OnPreviousPageBreezemoonsCommand}"
                                    Content="{materialDesign:PackIcon Kind=FirstPage,
                                                                      Size=18}"
                                    Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
                                    Style="{StaticResource MaterialDesignFloatingActionMiniSecondaryButton}" />
                                <Button
                                    Width="24"
                                    Height="24"
                                    Margin="0,2,0,0"
                                    Background="Transparent"
                                    Command="{Binding OnNextPageBreezemoonsCommand}"
                                    Content="{materialDesign:PackIcon Kind=LastPage,
                                                                      Size=18}"
                                    Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
                                    Style="{StaticResource MaterialDesignFloatingActionMiniSecondaryButton}" />
                            </StackPanel>
                        </Grid>

                    </Border>
                </materialDesign:DialogHost>
            </TabItem>

            <TabItem Header="set">
                <TabControl TabStripPlacement="Left">
                    <TabItem Header="API">
                        <StackPanel>
                            <TextBox
                                Margin="5"
                                materialDesign:HintAssist.Hint="Domain"
                                materialDesign:HintAssist.IsFloating="False"
                                materialDesign:TextFieldAssist.HasClearButton="True"
                                materialDesign:TextFieldAssist.HasOutlinedTextField="True"
                                Background="Transparent"
                                Style="{StaticResource MaterialDesignFilledTextBox}"
                                Text="{Binding Domain, Mode=TwoWay}" />
                            <PasswordBox
                                Margin="5"
                                materialDesign:HintAssist.Hint="Apikey"
                                materialDesign:HintAssist.IsFloating="False"
                                materialDesign:PasswordBoxAssist.Password="{Binding Apikey, Mode=TwoWay}"
                                materialDesign:TextFieldAssist.HasClearButton="True"
                                materialDesign:TextFieldAssist.HasOutlinedTextField="True"
                                Background="Transparent"
                                Style="{StaticResource MaterialDesignFilledRevealPasswordBox}" />
                            <Button
                                Margin="5"
                                HorizontalAlignment="Left"
                                Background="{DynamicResource {x:Static vsshell:VsBrushes.WindowKey}}"
                                Command="{Binding OnSaveSettingsCommand}"
                                Content="save"
                                Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}" />
                        </StackPanel>
                    </TabItem>
                    <TabItem Header="其他">
                        <StackPanel>
                            <TextBox
                                Margin="5"
                                materialDesign:HintAssist.Hint="小尾巴"
                                materialDesign:HintAssist.IsFloating="False"
                                materialDesign:TextFieldAssist.HasClearButton="True"
                                materialDesign:TextFieldAssist.HasOutlinedTextField="True"
                                Background="Transparent"
                                Style="{StaticResource MaterialDesignFilledTextBox}"
                                Text="{Binding MessageTail, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBox
                                Height="100"
                                Margin="5"
                                materialDesign:HintAssist.Hint="屏蔽机器人, 多条请换行"
                                materialDesign:HintAssist.IsFloating="False"
                                materialDesign:TextFieldAssist.HasClearButton="True"
                                materialDesign:TextFieldAssist.HasOutlinedTextField="True"
                                AcceptsReturn="True"
                                Background="Transparent"
                                Style="{StaticResource MaterialDesignFilledTextBox}"
                                Text="{Binding ShieldUsers, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                TextWrapping="Wrap" />

                            <Button
                                Margin="5"
                                HorizontalAlignment="Left"
                                Background="{DynamicResource {x:Static vsshell:VsBrushes.WindowKey}}"
                                Command="{Binding OnSaveOtherSettingsCommand}"
                                Content="save"
                                Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}" />
                        </StackPanel>
                    </TabItem>
                </TabControl>

            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
